// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: npx create-db

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/**
 * ENUMS
 */
enum IdeaGenerationRunStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum IdeaGenerationStageStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
}

enum UserRole {
  USER
  ADMIN
}

enum AccountStatus {
  NORMAL
  PREMIUM
}

enum ExternalServiceCategory {
  AI
  PAYMENT
  DATA_COLLECTION
  OTHER
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum PaymentPurpose {
  BUY_CREDITS
  DIRECT_UNLOCK
}

enum CreditTransactionType {
  PURCHASE
  BONUS
  DEDUCTION_GENERATION
  REFUND
  ADMIN_ADJUSTMENT
}

enum IdeaGenerationType {
  GUEST_FREE
  NORMAL_FREE
  PREMIUM_CREDIT
}

enum UnlockMethod {
  NONE
  DIRECT_PAYMENT
  CREDIT_GENERATION
}

enum ChatSender {
  USER
  AI
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  REJECTED
}

enum UserType {
  STUDENT
  DEVELOPER
  COMPANY
  RESEARCHER
  OTHER
}

enum ComplaintPriority {
  LOW
  MEDIUM
  HIGH
}

enum ContactMessageStatus {
  NEW
  IN_PROGRESS
  REPLIED
  CLOSED
}

enum AlertType {
  SYSTEM
  PAYMENT
  CREDIT_LOW
  CREDIT_EXHAUSTED
  ADMIN
}

enum IdeaPublicationVisibility {
  REGISTERED_USERS
  SELECTED_AUDIENCE
  PUBLIC
}

enum IdeaPublicationStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LanguageCode {
  ANY
  EN
  AR
  FR
  ES
  DE
  TR
}

enum ApiRequestType {
  DATA_COLLECTION
  COMMENT_ANALYSIS
  IDEA_GENERATION
  NLP_ENHANCEMENT
  AI_CHAT
  PAYMENT
  OTHER
}

enum AuditAction {
  // User administration
  ADMIN_UPDATE_USER_STATUS
  ADMIN_SOFT_DELETE_USER
  ADMIN_ADJUST_USER_CREDITS
  ADMIN_SEND_PASSWORD_RESET_EMAIL

  // System settings and prompts
  ADMIN_UPDATE_SETTINGS
  ADMIN_UPDATE_PROMPT

  // Alerts
  ADMIN_CREATE_ALERT

  // Platforms
  ADMIN_CREATE_DATA_SOURCE
  ADMIN_UPDATE_DATA_SOURCE
  ADMIN_ACTIVATE_DATA_SOURCE
  ADMIN_DEACTIVATE_DATA_SOURCE

  // Domains
  ADMIN_CREATE_DOMAIN
  ADMIN_UPDATE_DOMAIN
  ADMIN_DEACTIVATE_DOMAIN

  // Complaints and contact messages
  ADMIN_UPDATE_COMPLAINT
  ADMIN_UPDATE_CONTACT_MESSAGE

  // AI model management
  ADMIN_CREATE_AI_MODEL
  ADMIN_UPDATE_AI_MODEL
  ADMIN_ACTIVATE_AI_MODEL
  ADMIN_DEACTIVATE_AI_MODEL
  ADMIN_SET_DEFAULT_AI_MODEL

  // Data collection
  RUN_DATA_COLLECTION
  COMPLETE_DATA_COLLECTION
  FAIL_DATA_COLLECTION
  STOP_DATA_COLLECTION
  ADMIN_START_DATA_COLLECTION
  ADMIN_STOP_DATA_COLLECTION

  // User operations
  USER_GENERATE_IDEA
  USER_UNLOCK_IDEA
  USER_CREATE_COMPLAINT
  USER_CREATE_CONTACT_MESSAGE
  USER_AI_CHAT
  USER_UPDATE_PROFILE
  USER_MARK_NOTIFICATION_READ
  USER_MARK_ALL_NOTIFICATIONS_READ

  // Pipeline operations
  NLP_ANALYSIS_RUN
  ABSTRACT_GENERATION_RUN
  PROMPT_HISTORY_CREATED

  USER_CREATE_PUBLICATION
  USER_PUBLISH_IDEA
  USER_UPDATE_PUBLICATION
  USER_ARCHIVE_PUBLICATION
}

enum AiModelHealthStatus {
  UNKNOWN
  HEALTHY
  DEGRADED
  UNAVAILABLE
}

enum AiRoutingStrategy {
  DEFAULT
  LOWEST_COST
  BALANCED
}

enum AuditTargetType {
  USER
  IDEA
  PAYMENT
  DOMAIN
  DATA_SOURCE
  SYSTEM_SETTING
  PROMPT
  COMPLAINT
  AI_MODEL
  IDEA_PUBLICATION

  CONTACT_MESSAGE
  ALERT
  CREDIT_TRANSACTION
  DATA_COLLECTION
  NLP_ANALYSIS
}

enum AuthAction {
  REGISTER
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  REFRESH_TOKEN
  CHANGE_PASSWORD
  FORGOT_PASSWORD
  RESET_PASSWORD
  EMAIL_VERIFIED
  RESEND_VERIFICATION_EMAIL
  ACCOUNT_LOCKED
  ACCOUNT_DEACTIVATED
  EMAIL_CHANGED
  VERIFICATION_EMAIL_SENT
  VERIFY_EMAIL_FAILED
  RESET_PASSWORD_FAILED
  REFRESH_TOKEN_FAILED
}

enum CollectionJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  STOPPED
}

model DataSource {
  id String @id @default(uuid())

  /**
   * Stable code identifier used by the backend registry.
   * Examples: youtube, github, dev-to, google-play.
   */
  key String @unique

  displayName String  @map("display_name")
  description String?

  isActive Boolean @default(true) @map("is_active")

  /**
   * Indicates whether the collector implementation is currently
   * available in the deployed backend.
   */
  isImplemented Boolean @default(false) @map("is_implemented")

  supportsPosts    Boolean @default(true) @map("supports_posts")
  supportsComments Boolean @default(false) @map("supports_comments")
  supportsRegion   Boolean @default(false) @map("supports_region")
  supportsLanguage Boolean @default(false) @map("supports_language")

  configuration Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  collectionJobSources CollectionJobSource[]
  socialPosts          SocialPost[]

  @@index([isActive])
  @@index([isImplemented])
  @@map("data_sources")
}

model CollectionJobSource {
  id String @id @default(uuid())

  collectionJobId String        @map("collection_job_id")
  collectionJob   CollectionJob @relation(fields: [collectionJobId], references: [id], onDelete: Cascade)

  dataSourceId String     @map("data_source_id")
  dataSource   DataSource @relation(fields: [dataSourceId], references: [id], onDelete: Restrict)

  status CollectionJobStatus @default(PENDING)

  totalPosts    Int @default(0) @map("total_posts")
  totalComments Int @default(0) @map("total_comments")

  startedAt     DateTime? @map("started_at")
  completedAt   DateTime? @map("completed_at")
  failureReason String?   @map("failure_reason")

  @@unique([collectionJobId, dataSourceId])
  @@index([collectionJobId])
  @@index([dataSourceId])
  @@index([status])
  @@map("collection_job_sources")
}

enum PromptType {
  IDEA_GENERATION
  IDEA_UNLOCK
  CHAT_RESPONSE
  NLP_ANALYSIS
  ABSTRACT_GENERATION
}

enum NlpLexiconType {
  PROBLEM
  NEED
  POSITIVE
  NEGATIVE

  FEATURE_REQUEST
  COMPLAINT
  URGENCY
  COST
  TIME
  ACCESSIBILITY
  SAFETY
  RELIABILITY
  OPPORTUNITY
}

/**
 * USERS
 */

model User {
  id                String        @id @default(uuid())
  fullName          String        @map("full_name")
  email             String        @unique
  passwordHash      String        @map("password_hash")
  role              UserRole      @default(USER)
  emailVerifiedAt   DateTime?     @map("email_verified_at")
  lastLoginAt       DateTime?     @map("last_login_at")
  passwordChangedAt DateTime?     @map("password_changed_at")
  accountStatus     AccountStatus @default(NORMAL) @map("account_status")

  freeGenerationLimit Int @default(3) @map("free_generation_limit")
  freeGenerationsUsed Int @default(0) @map("free_generations_used")
  creditBalance       Int @default(0) @map("credit_balance")

  isActive   Boolean @default(true) @map("is_active")
  isVerified Boolean @default(false) @map("is_verified")

  failedLoginAttempts        Int       @default(0) @map("failed_login_attempts")
  failedLoginWindowStartedAt DateTime? @map("failed_login_window_started_at")
  loginLockLevel             Int       @default(0) @map("login_lock_level")
  lockedUntil                DateTime? @map("locked_until")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  userType  UserType?

  ideas                   Idea[]
  payments                Payment[]
  creditTransactions      CreditTransaction[]
  chatSessions            ChatSession[]
  alerts                  Alert[]
  complaints              Complaint[]
  externalApiLogs         ExternalApiLog[]
  auditLogs               AuditLog[]               @relation("AuditLogs")
  updatedSettings         SystemSetting[]          @relation("SettingsUpdatedBy")
  refreshTokens           RefreshToken[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  authenticationLogs      AuthenticationLog[]
  favoritePublications    FavoritePublication[]
  preference              UserPreference?
  savedGenerationSearches SavedGenerationSearch[]
  contactMessages         ContactMessage[]
  deletedAt               DateTime?                @map("deleted_at")

  /**
   * Prompts requested by this authenticated user.
   * Guest prompts are linked through GuestSession instead.
   */
  promptHistories PromptHistory[]
  publishedIdeas  IdeaPublication[] @relation("PublishedIdeas")

  publicationRatings  IdeaPublicationRating[]
  publicationVotes    IdeaPublicationVote[]
  publicationFeedback IdeaPublicationFeedback[]
  generationRuns      IdeaGenerationRun[]
  collectionJobs      CollectionJob[]           @relation("CollectionJobsCreatedBy")

  @@index([lockedUntil])
  @@index([loginLockLevel])
  @@map("users")
}

/**
 * Refresh Token
 */

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  ipAddress  String?   @map("ip_address")
  userAgent  String?   @map("user_agent")
  lastUsedAt DateTime? @map("last_used_at")

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("refresh_tokens")
}

/**
 * Password Reset Token
 */
model PasswordResetToken {
  id        String @id @default(uuid())
  userId    String @map("user_id")
  tokenHash String @unique @map("token_hash")

  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
  @@map("password_reset_tokens")
}

model SystemSetting {
  id String @id @default(uuid())

  /**
   * Guarantees that only one global system-settings row exists.
   */
  key String @unique @default("GLOBAL")

  /**
   * Price of one credit.
   * One credit allows one premium idea generation.
   */
  creditPrice Decimal @map("credit_price") @db.Decimal(10, 2)

  /**
   * Price paid directly to unlock advanced features
   * for one previously generated free idea.
   * This payment does not purchase or consume credits.
   */
  directUnlockPrice Decimal @default(10) @map("direct_unlock_price") @db.Decimal(10, 2)

  /**
   * Minimum number of purchased credits required
   * to receive bonus credits.
   */
  bonusThreshold Int @default(0) @map("bonus_threshold")

  /**
   * Number of bonus credits granted when the
   * configured threshold is reached.
   */
  bonusCredits Int @default(0) @map("bonus_credits")

  ideaPromptTemplate String? @map("idea_prompt_template")

  updatedById String? @map("updated_by")

  updatedBy User? @relation("SettingsUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model AuditLog {
  id String @id @default(uuid())

  actorId String? @map("actor_id")
  actor   User?   @relation("AuditLogs", fields: [actorId], references: [id], onDelete: SetNull)

  action AuditAction

  targetType AuditTargetType @map("target_type")
  targetId   String?         @map("target_id")

  oldValue Json? @map("old_value")
  newValue Json? @map("new_value")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([actorId])
  @@index([action])
  @@index([targetType])
  @@index([createdAt])
  @@index([targetType, targetId])
  @@map("audit_logs")
}

model GuestSession {
  id String @id @default(uuid())

  /**
   * Public random identifier stored in a secure HTTP-only cookie.
   */
  sessionToken String @unique @map("session_token")

  /**
   * One-way hash derived from request information.
   * Prevents the same guest client from repeatedly creating
   * new sessions after consuming the free guest generation.
   */
  fingerprintHash String @unique @map("fingerprint_hash")

  hasGenerated Boolean @default(false) @map("has_generated")

  createdAt DateTime  @default(now()) @map("created_at")
  expiresAt DateTime? @map("expires_at")

  ideas           Idea[]
  generationRuns  IdeaGenerationRun[]
  promptHistories PromptHistory[]

  @@index([expiresAt])
  @@map("guest_sessions")
}

model Idea {
  id String @id @default(uuid())

  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  guestSessionId String?       @map("guest_session_id")
  guestSession   GuestSession? @relation(fields: [guestSessionId], references: [id], onDelete: Restrict)

  publication   IdeaPublication?
  generationRun IdeaGenerationRun?
  deletedAt     DateTime?          @map("deleted_at")

  title String

  domainId String @map("domain_id")
  domain   Domain @relation(fields: [domainId], references: [id], onDelete: Restrict)

  selectedRegion String? @map("selected_region")

  limitedAbstract String? @map("limited_abstract")
  partialAbstract String? @map("partial_abstract")
  fullAbstract    String? @map("full_abstract")

  problemStatement String? @map("problem_statement")
  objectives       String?
  targetUsers      String? @map("target_users")

  generationType IdeaGenerationType @map("generation_type")

  isUnlocked   Boolean      @default(false) @map("is_unlocked")
  unlockMethod UnlockMethod @default(NONE) @map("unlock_method")
  unlockedAt   DateTime?    @map("unlocked_at")

  collectionJobId String?        @map("collection_job_id")
  collectionJob   CollectionJob? @relation(fields: [collectionJobId], references: [id], onDelete: SetNull)

  commentsCount Int @default(0) @map("comments_count")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  promptHistories    PromptHistory[]
  payments           Payment[]
  creditTransactions CreditTransaction[]
  chatSessions       ChatSession[]
  generatedOutputs   GeneratedOutput[]
  complaints         Complaint[]
  externalApiLogs    ExternalApiLog[]

  @@index([userId, createdAt])
  @@index([guestSessionId])
  @@index([generationType])
  @@index([isUnlocked])
  @@index([collectionJobId])
  @@map("ideas")
}

model Payment {
  id String @id @default(uuid())

  userId         String  @map("user_id")
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  idempotencyKey String? @unique @map("idempotency_key")
  ideaId         String? @map("idea_id")
  idea           Idea?   @relation(fields: [ideaId], references: [id], onDelete: SetNull)

  amount   Decimal @db.Decimal(10, 2)
  currency String  @default("USD")

  /**
   * User-facing method.
   * Examples: card, paypal.
   */
  paymentMethodKey String @map("payment_method_key")

  /**
   * Backend gateway implementation.
   * Examples: stripe, paypal.
   */
  providerKey String @map("provider_key")

  status PaymentStatus @default(PENDING)

  paymentPurpose PaymentPurpose @map("payment_purpose")

  creditsAmount      Int @default(0) @map("credits_amount")
  bonusCreditsAmount Int @default(0) @map("bonus_credits_amount")

  creditPriceAtPurchase Decimal? @map("credit_price_at_purchase") @db.Decimal(10, 2)

  providerPaymentId String? @unique @map("provider_payment_id")
  providerSessionId String? @unique @map("provider_session_id")

  transactionReference String? @map("transaction_reference")
  failureReason        String? @map("failure_reason")

  paidAt     DateTime? @map("paid_at")
  failedAt   DateTime? @map("failed_at")
  refundedAt DateTime? @map("refunded_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  creditTransactions CreditTransaction[]

  @@index([userId])
  @@index([ideaId])
  @@index([status])
  @@index([providerKey])
  @@index([paymentMethodKey])
  @@index([paymentPurpose])
  @@index([createdAt])
  @@map("payments")
}

/**
 * CREDIT TRANSACTIONS
 */

model CreditTransaction {
  id String @id @default(uuid())

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  paymentId String?  @map("payment_id")
  payment   Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  ideaId String? @map("idea_id")
  idea   Idea?   @relation(fields: [ideaId], references: [id], onDelete: SetNull)

  type         CreditTransactionType
  amount       Int
  balanceAfter Int                   @map("balance_after")
  description  String?

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([paymentId, type])
  @@index([userId])
  @@index([paymentId])
  @@index([ideaId])
  @@index([type])
  @@index([createdAt])
  @@map("credit_transactions")
}

/**
 * CHAT
 */

model ChatSession {
  id String @id @default(uuid())

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  ideaId String @map("idea_id")
  idea   Idea   @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  title String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  messages ChatMessage[]

  @@index([userId])
  @@index([ideaId])
  @@index([createdAt])
  @@map("chat_sessions")
}

model ChatMessage {
  id String @id @default(uuid())

  sessionId String      @map("session_id")
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  sender  ChatSender
  message String

  createdAt DateTime @default(now()) @map("created_at")

  @@index([sessionId, createdAt])
  @@map("chat_messages")
}

/**
 * ALERTS
 */

model Alert {
  id String @id @default(uuid())

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title   String
  message String
  type    AlertType @default(SYSTEM)
  isRead  Boolean   @default(false) @map("is_read")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("alerts")
}

/**
 * COMPLAINTS
 */

model Complaint {
  id String @id @default(uuid())

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  ideaId    String?   @map("idea_id")
  idea      Idea?     @relation(fields: [ideaId], references: [id], onDelete: SetNull)
  deletedAt DateTime? @map("deleted_at")

  subject  String
  message  String
  status   ComplaintStatus   @default(OPEN)
  priority ComplaintPriority @default(MEDIUM)

  adminReply String? @map("admin_reply")

  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  resolvedAt DateTime? @map("resolved_at")

  @@index([userId])
  @@index([ideaId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
  @@map("complaints")
}

model ExternalApiLog {
  id String @id @default(uuid())

  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  ideaId String? @map("idea_id")
  idea   Idea?   @relation(fields: [ideaId], references: [id], onDelete: SetNull)

  aiModelId String?  @map("ai_model_id")
  aiModel   AiModel? @relation(fields: [aiModelId], references: [id], onDelete: SetNull)

  serviceCategory ExternalServiceCategory @map("service_category")

  /**
   * Examples: openrouter, google, stripe, youtube.
   */
  providerKey String @map("provider_key")

  endpoint    String?
  requestId   String?        @map("request_id")
  requestType ApiRequestType @map("request_type")

  operationId   String? @map("operation_id")
  attemptNumber Int     @default(1) @map("attempt_number")
  fallbackUsed  Boolean @default(false) @map("fallback_used")

  statusCode Int?    @map("status_code")
  isSuccess  Boolean @default(false) @map("is_success")

  responseTimeMs Int?     @map("response_time_ms")
  errorMessage   String?  @map("error_message")
  costEstimate   Decimal? @map("cost_estimate") @db.Decimal(12, 6)

  apiModelId   String? @map("api_model_id")
  inputTokens  Int?    @map("input_tokens")
  outputTokens Int?    @map("output_tokens")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([aiModelId, createdAt])
  @@index([operationId])
  @@index([providerKey, createdAt])
  @@index([serviceCategory, createdAt])
  @@index([requestType, createdAt])
  @@index([isSuccess, createdAt])
  @@index([userId, createdAt])
  @@index([ideaId, createdAt])
  @@map("external_api_logs")
}

/**
 * Domain
 */

model Domain {
  id             String          @id @default(uuid())
  name           String          @unique
  isActive       Boolean         @default(true) @map("is_active")
  domainKeywords DomainKeyword[]

  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  collectionJobs CollectionJob[]

  ideas                   Idea[]
  savedGenerationSearches SavedGenerationSearch[]
  topicRules              NlpTopicRule[]

  @@map("domains")
}

model DomainKeyword {
  id String @id @default(uuid())

  domainId String @map("domain_id")
  domain   Domain @relation(fields: [domainId], references: [id], onDelete: Cascade)

  keyword  String
  language LanguageCode @default(ANY)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([domainId, keyword, language])
  @@index([domainId])
  @@index([language])
  @@map("domain_keywords")
}

model EmailVerificationToken {
  id        String @id @default(uuid())
  userId    String @map("user_id")
  tokenHash String @unique @map("token_hash")

  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
  @@map("email_verification_tokens")
}

model AuthenticationLog {
  id String @id @default(uuid())

  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  action AuthAction

  email     String?
  isSuccess Boolean @default(true) @map("is_success")
  message   String?

  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([action])
  @@index([email])
  @@index([createdAt])
  @@map("authentication_logs")
}

model CollectionJob {
  id String @id @default(uuid())

  /**
   * User who started or owns this collection job.
   * Nullable to support guest, internal, and legacy jobs.
   */
  createdById String? @map("created_by_id")

  createdBy User? @relation("CollectionJobsCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  domainId String @map("domain_id")

  domain Domain @relation(fields: [domainId], references: [id], onDelete: Restrict)

  language LanguageCode

  country  String?
  city     String?
  region   String?
  radiusKm Int?    @map("radius_km")

  keywords Json?

  status CollectionJobStatus @default(PENDING)

  totalPosts    Int @default(0) @map("total_posts")
  totalComments Int @default(0) @map("total_comments")

  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")

