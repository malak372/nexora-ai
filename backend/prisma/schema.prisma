/**
 * Distributed lock for expensive idea-generation workflows.
 * Prevents concurrent requests from:
 * - Calling AI more than once for the same entitlement.
 * - Consuming the same final free attempt.
 * - Consuming the same premium credit.
 * The lock is stored in PostgreSQL and therefore works across
 * multiple backend instances.
 */
model IdeaGenerationLock {
  id String @id @default(uuid())

  /**
   * Examples:
   * - user:<userId>
   * - guest:<guestSessionId>
   */
  lockKey String @unique @map("lock_key")

  ownerToken String @map("owner_token")

  expiresAt DateTime @map("expires_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("idea_generation_locks")
}

model IdeaPublication {
  id String @id @default(uuid())

  ideaId String @unique @map("idea_id")
  idea   Idea   @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  publisherId String @map("publisher_id")
  publisher   User   @relation("PublishedIdeas", fields: [publisherId], references: [id], onDelete: Cascade)

  status IdeaPublicationStatus @default(DRAFT)

  visibility IdeaPublicationVisibility

  /**
   * Safe public snapshot.
   * These fields are copied from Idea when publishing.
   * Internal paid details are never exposed directly.
   */
  publicTitle       String                    @map("public_title")
  publicAbstract    String?                   @map("public_abstract")
  publicProblem     String?                   @map("public_problem")
  publicObjectives  String?                   @map("public_objectives")
  revisions         IdeaPublicationRevision[]
  publicTargetUsers String?                   @map("public_target_users")

  allowRatings  Boolean               @default(true) @map("allow_ratings")
  allowFeedback Boolean               @default(true) @map("allow_feedback")
  allowVoting   Boolean               @default(true) @map("allow_voting")
  favorites     FavoritePublication[]

  averageRating Decimal @default(0) @map("average_rating") @db.Decimal(3, 2)

  ratingsCount Int @default(0) @map("ratings_count")

  upvotesCount   Int @default(0) @map("upvotes_count")
  downvotesCount Int @default(0) @map("downvotes_count")
  feedbackCount  Int @default(0) @map("feedback_count")

  publishedAt DateTime? @map("published_at")
  archivedAt  DateTime? @map("archived_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  audiences IdeaPublicationAudience[]
  ratings   IdeaPublicationRating[]
  votes     IdeaPublicationVote[]
  feedback  IdeaPublicationFeedback[]

  @@index([status, visibility, publishedAt])
  @@index([publisherId, status, createdAt])
  @@index([status, publishedAt])
  @@index([publisherId])
  @@index([averageRating])
  @@index([upvotesCount])
  @@map("idea_publications")
}

