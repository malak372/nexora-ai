model NlpLexicon {
  id String @id @default(uuid())

  word     String
  type     NlpLexiconType
  language LanguageCode   @default(ANY)

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  /// Prevent duplicate lexicon entries for the same word, category, and language.
  @@unique([word, type, language])
  /// Used when querying lexicon entries by language.
  @@index([language])
  /// Optimizes the most common NLP lookup:
  /// WHERE type = ? AND language IN (?, ANY)
  @@index([type, language])
  /// Speeds up filtering active lexicon entries.
  @@index([isActive])
  @@map("nlp_lexicons")
}

