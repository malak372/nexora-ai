model PromptHistory {
  id String @id @default(uuid())

  /**
   * Registered user who requested the prompt.
   * Null when the prompt was requested by a guest session.
   */
  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  /**
   * Guest session that requested the prompt.
   * Null when the prompt was requested by an authenticated user.
   */
  guestSessionId String?       @map("guest_session_id")
  guestSession   GuestSession? @relation(fields: [guestSessionId], references: [id], onDelete: SetNull)

  /**
   * Collection job supplying the persisted NLP analysis.
   */
  collectionJobId String?        @map("collection_job_id")
  collectionJob   CollectionJob? @relation(fields: [collectionJobId], references: [id], onDelete: SetNull)

  /**
   * Idea associated with this prompt-history record.
   */
  ideaId String? @map("idea_id")
  idea   Idea?   @relation(fields: [ideaId], references: [id], onDelete: SetNull)

  /**
   * Determines the operation for which the prompt was built.
   */
  promptType PromptType @map("prompt_type")

  /**
   * Complete rendered prompt sent to the AI provider.
   */
  promptText String @map("prompt_text")

  /**
   * SHA-256 hash of the template used to build the prompt.
   */
  templateHash String? @map("template_hash")

  /**
   * Estimated number of input tokens in the rendered prompt.
   */
  estimatedInputTokens Int? @map("estimated_input_tokens")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([guestSessionId])
  @@index([collectionJobId])
  @@index([ideaId])
  @@index([promptType])
  @@index([templateHash])
  @@index([createdAt])
  @@map("prompt_histories")
}

